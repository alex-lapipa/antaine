# ANTAINE — frontend environment (Vercel project prj_OfelufhDEN5eLlsWtSz0A3qXjykI)

# Shopify Storefront API (headless cart + checkout)
VITE_SHOPIFY_DOMAIN=antaine.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Privacy-friendly, cookieless analytics (loads ONLY after visitor consent).
# Leave unset to disable analytics entirely. Set to the site's domain once added in Plausible.
VITE_PLAUSIBLE_DOMAIN=antaine.xyz
# Optional: self-hosted/proxied Plausible script URL (defaults to https://plausible.io/js/script.js)
# VITE_PLAUSIBLE_SRC=
